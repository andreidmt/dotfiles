#!/usr/bin/env sh

# NAME
#   usb-automount - Automount removable devices (USB drives, SD cards)
#
# SYNOPSIS
#   sv start $CORE_RUNSV/usb-automount
#
# DESCRIPTION
#   Polls for removable devices and mounts them via usbauto-ctl.
#   Mounts to /run/media/$USER/<label>.
#
#   For GUI feedback (notifications, file manager), use usbauto-sway
#   in your sway config.
#
# DEPENDENCIES
#   usbauto-ctl, lsremovable
#
# SEE ALSO
#   usbauto-ctl, usbauto-sway, usbauto-rofi

# ╭───┤ Functions
# ╰─

cleanup() {
  echo "Service stopped"
  exit 0
}
trap cleanup TERM INT

# ╭───┤ Main. Start here.
# ╰─

echo "Watching for USB and SD cards"

prev_partitions=$(lsremovable | awk '{print $1}')

while true; do
  next_partitions=$(lsremovable | awk '{print $1}')

  # Mount new partitions (in next but not in prev)
  for partition in $next_partitions; do
    if ! echo "$prev_partitions" | grep -q "$partition"; then
      if mount_path=$(usbauto-ctl mount "$partition"); then
        echo "Mounted: $partition → $mount_path"
      fi
    fi
  done

  # Unmount removed partitions (in prev but not in next)
  for partition in $prev_partitions; do
    if ! echo "$next_partitions" | grep -q "$partition"; then
      usbauto-ctl unmount "$partition"
      echo "Unmounted: $partition"
    fi
  done

  sleep 0.5
  prev_partitions="$next_partitions"
done
