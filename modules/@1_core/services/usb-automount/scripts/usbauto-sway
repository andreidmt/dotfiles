#!/usr/bin/env sh

# NAME
#   usbauto-sway - GUI companion for usb-automount
#
# SYNOPSIS
#   exec usbauto-sway (in sway config)
#
# DESCRIPTION
#   Watches /run/media/$USER for mount/unmount events and provides GUI feedback:
#   - Desktop notifications via doomst
#   - Opens nnn in alacritty on mount
#   - Closes nnn window on unmount
#
# DEPENDENCIES
#   inotify-tools, usbauto-ctl, doomst, swaymsg, beep_mount, beep_eject
#
# SEE ALSO
#   usbauto-ctl, usbauto-rofi, usb-automount

# ╭───┤ Bootstrap
# ╰─

MEDIA_DIR="/run/media/$USER"

# ╭───┤ Functions
# ╰─

# Handle mount event: notify, beep, open file manager.
on_mount() {
  mount_path="$1"
  label=$(basename "$mount_path")

  # Wait for mount to complete (directory created before mount finishes)
  while ! findmnt -no SOURCE "$mount_path" 2>/dev/null; do
    sleep 0.2
  done

  beep_mount &
  doomst --type info "USB Automount" "Mounted: $mount_path"
  usbauto-ctl open "$mount_path"
}

# Handle unmount event: close file manager, notify, beep.
on_unmount() {
  label="$1"

  beep_eject &
  swaymsg "[title=\"^nnn - .* - $label$\"] kill" >/dev/null 2>&1
  doomst --type info "USB Automount" "Unmounted: $label"
}

# ╭───┤ Main. Start here.
# ╰─

mkdir -p "$MEDIA_DIR"

inotifywait -m -e create -e delete --format '%e %f' "$MEDIA_DIR" 2>/dev/null | while read -r event name; do
  case "$event" in
    CREATE*) on_mount "$MEDIA_DIR/$name" ;;
    DELETE*) on_unmount "$name" ;;
  esac
done
