#!/usr/bin/env sh

# ╭─────────┤ check-installed-pkg
# │ Exit with error if any of the given commands are not found
# │
# │ SYNOPSIS
# │   check-installed-pkg cmd1 [cmd2 ...]
# │
# │ EXAMPLE
# │   check-installed-pkg git fzf yank
# │
# │ SEE ALSO
# │   command(1)
# ╰────

# ╭───
# │ Bootstrap
# ╰───

[ -z "${1:-}" ] && {
  echo "Usage: check-installed-pkg cmd1 [cmd2 ...]" >&2
  exit 1
}

# ╭───
# │ Main
# ╰───

missing=""
for cmd in "$@"; do
  command -v "$cmd" >/dev/null 2>&1 || {
    missing="${missing}${missing:+, }$cmd"
  }
done

[ -n "$missing" ] && {
  echo "Missing required commands: $missing" >&2
  exit 1
}
