#!/usr/bin/env sh

# ╭─────────┤ yank
# │ Display-manager aware copy to clipboard
# │
# │ SYNOPSIS
# │   yank [INPUT ...]
# │   ... | yank
# │
# │ DESCRIPTION
# │   Copies input (args or stdin) to clipboard. Uses wl-copy on
# │   Wayland, xsel on X11.
# │
# │ SEE ALSO
# │   wl-copy(1), xsel(1), fancy-log(1)
# ╰────

# ╭───
# │ Bootstrap
# ╰───

export LOG_NAMESPACE="yank"
! command -v fancy-log >/dev/null 2>&1 && {
  echo "Missing required commands: fancy-log" >&2
  exit 1
}

# ╭───
# │ Main
# ╰───

if [ ! -t 0 ]; then
  input=$(cat)
else
  input="$*"
fi

[ -z "$input" ] && {
  fancy-log error "No input provided."
  exit 1
}

# Wayland
command -v wl-copy >/dev/null 2>&1 && {
  printf "%s" "$input" | wl-copy
  exit 0
}

# X11
command -v xsel >/dev/null 2>&1 && {
  printf "%s" "$input" | xsel --primary --input
  printf "%s" "$input" | xsel --clipboard --input
  exit 0
}

fancy-log error "Neither wl-copy nor xsel found."
exit 1
