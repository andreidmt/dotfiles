#!/usr/bin/env sh

###
# `@0_fancy-posix-utils` module loading script.
#
# Sourced with every terminal session, after `.bootstrap`.
# Initialize and kickstart module's responsabilities.
###

# Expose module scripts
case ":$PATH:" in
  *":$FCLI_SCRIPTS:"*) ;;
  *) export PATH="$FCLI_SCRIPTS:$PATH" ;;
esac

# Expose module functions
. "$FCLI_FUNCTIONS/guards"
. "$FCLI_FUNCTIONS/predicates"
. "$FCLI_FUNCTIONS/stdin-or"
. "$FCLI_FUNCTIONS/symlinks"
