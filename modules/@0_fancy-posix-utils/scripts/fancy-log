#!/usr/bin/env sh

# в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”¤ fancy-log
# в”‚ Dated, colored, namespaced log messages
# в”‚
# в”‚ SYNOPSIS
# в”‚   fancy-log <level> [-v <key> <val>]... <message>
# в”‚
# в”‚ LEVELS
# в”‚   error, warning, info, success
# в”‚
# в”‚ OPTIONS
# в”‚   -v <key> <val>    Append key=val pair after message
# в”‚   -nc, --no-color   Strip colors (auto if CI is set)
# в”‚
# в”‚ ENVIRONMENT
# в”‚   LOG_LEVEL       Minimum level to print (default: error)
# в”‚   LOG_NAMESPACE   Prefix label (gray, before message)
# в”‚   CI              If set, disables colors
# в”‚
# в”‚ EXAMPLE
# в”‚   fancy-log error -v param "bad" "Invalid parameter"
# в”‚
# в”‚ SEE ALSO
# в”‚   color(1)
# в•°в”Ђв”Ђв”Ђв”Ђ

# в•­в”Ђв”Ђв”Ђ
# в”‚ Primitives
# в•°в”Ђв”Ђв”Ђ

LOG_LEVEL="${LOG_LEVEL:-error}"

# Map level name to numeric priority
level_num() {
  case "$1" in
    err | error) echo 0 ;;
    warn | warning) echo 1 ;;
    info) echo 2 ;;
    success | succ) echo 3 ;;
    *) echo 9 ;;
  esac
}

# Map LOG_LEVEL to max numeric threshold
threshold_num() {
  case "$1" in
    err | error) echo 0 ;;
    warn | warning) echo 1 ;;
    info) echo 2 ;;
    *) echo 0 ;;
  esac
}

should_print() {
  level=$(level_num "$1")
  threshold=$(threshold_num "$LOG_LEVEL")

  # success always prints
  [ "$1" = "success" ] || [ "$1" = "succ" ] && return 0
  [ "$level" -le "$threshold" ]
}

set_theme() {
  case "$1" in
    err | error)
      TYPE_LABEL="ERR"
      TYPE_COLOR=31
      ;;
    warn | warning)
      TYPE_LABEL="WRN"
      TYPE_COLOR=33
      ;;
    info)
      TYPE_LABEL="INF"
      TYPE_COLOR=34
      ;;
    success | succ)
      TYPE_LABEL="SUC"
      TYPE_COLOR=32
      ;;
  esac
}

# в•­в”Ђв”Ђв”Ђ
# в”‚ Main
# в•°в”Ђв”Ђв”Ђ

[ -z "${1:-}" ] && {
  echo "Usage: fancy-log <level> [-v <key> <val>]... <message>" >&2
  exit 1
}

msg_type="$1"
shift

should_print "$msg_type" || exit 0
set_theme "$msg_type"

# Parse options
has_color=$([ -n "${CI:-}" ] && echo "" || echo "true")
variables=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    -nc | --no-color)
      has_color=""
      shift
      ;;
    -v | --var)
      key="$2"
      val="$3"
      shift 3

      if [ -n "$has_color" ]; then
        variables="${variables}\033[90m${key}=\033[0m${val} "
      else
        variables="${variables}${key}=${val} "
      fi
      ;;
    --)
      shift
      break
      ;;
    -?*)
      echo "Unknown flag: $1" >&2
      exit 1
      ;;
    *) break ;;
  esac
done

timestamp=$(date +%T)

if [ -n "$has_color" ]; then
  label="\033[${TYPE_COLOR}m\033[1m${TYPE_LABEL}\033[0m"
  ns="${LOG_NAMESPACE:+\033[90m${LOG_NAMESPACE}: \033[0m}"
  printf "%s %b %b%s %b\n" "$timestamp" "$label" "$ns" "$1" "$variables" >&2
else
  ns="${LOG_NAMESPACE:+${LOG_NAMESPACE}: }"
  printf "%s %s %s%s %s\n" "$timestamp" "$TYPE_LABEL" "$ns" "$1" "$variables" >&2
fi
