#!/usr/bin/env sh

# ╭─────────┤ jot
# │ Quick note in Neovim, output to stdout
# │
# │ SYNOPSIS
# │   jot [-c|--continue]
# │   ... | jot
# │   jot | wc -c
# │
# │ DESCRIPTION
# │   Opens a temp file in Neovim (via Alacritty), then echoes the
# │   result to stdout. Piped input is prepended. Think extended echo.
# │
# │ OPTIONS
# │   -c, --continue   Resume editing the last note
# │   -h, --help       Show man page
# │
# │ EXAMPLES
# │   jot > ~/notes/$(date +%Y-%m-%d).md
# │   cat fn.js | jot "explain:" | ai
# │
# │ ENVIRONMENT
# │   JOT_HOME   State directory (default: ~/.jot)
# │
# │ SEE ALSO
# │   nvim(1), alacritty(1), fancy-log(1)
# ╰────

# ╭───
# │ Bootstrap
# ╰───

export LOG_NAMESPACE="jot"
export LOG_LEVEL="${LOG_LEVEL:-info}"
check-installed-pkg fancy-log alacritty nvim

JOT_HOME="${JOT_HOME:-${HOME}/.jot}"
mkdir -p "$JOT_HOME"

PREV_NOTE_PATH="${JOT_HOME}/last_note_path"
SHOULD_CONTINUE=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h | --help)
      man --pager cat "$(dirname "$0")/jot.1"
      exit 0
      ;;
    -c | --continue)
      SHOULD_CONTINUE=true
      shift
      ;;
    --)
      shift
      break
      ;;
    -?*)
      fancy-log error -v flag "$1" "Unknown flag."
      exit 1
      ;;
    *) break ;;
  esac
done

# ╭───
# │ Main
# ╰───

# Resolve temp file — reuse previous or create new
TMP_FILE=""
[ "$SHOULD_CONTINUE" = true ] && [ -f "$PREV_NOTE_PATH" ] && {
  TMP_FILE=$(cat "$PREV_NOTE_PATH" 2>/dev/null)
}
[ -z "$TMP_FILE" ] && TMP_FILE=$(mktemp /tmp/jot.XXXXXX)
[ -z "$TMP_FILE" ] && {
  fancy-log error "Could not create temporary file."
  exit 1
}

# Drain stdin into file if piped
[ ! -t 0 ] && cat >>"$TMP_FILE"

# Edit — WM class for i3/sway floating rules
alacritty --title "$TMP_FILE - jot" \
  --class "jot-center-float" \
  --command nvim \
  -c "setlocal syntax=markdown" \
  -c "setlocal wrap" \
  -c "setlocal spell" \
  "$TMP_FILE"

# Output and persist
text=$(cat "$TMP_FILE")
[ -z "$text" ] && {
  fancy-log info "No text entered."
  exit 0
}

printf "%s" "$text"
printf "%s" "$TMP_FILE" >"$PREV_NOTE_PATH"
